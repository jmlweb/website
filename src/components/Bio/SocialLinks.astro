---
import { Sprite } from 'astro-icon';

const LINKS = [
  {
    href: 'https://github.com/jmlweb',
    title: 'GitHub',
    icon: 'ri:github-line',
  },
  {
    href: 'https://www.linkedin.com/in/josemanuellucas',
    title: 'LinkedIn',
    icon: 'ri:linkedin-line',
  },
  {
    href: 'https://twitter.com/jmlweb',
    title: 'Twitter',
    icon: 'ri:twitter-x-line',
  },
];
---

<footer role="group">
  {
    LINKS.map(({ href, title, icon }) => (
      <a href={href} data-tooltip target="_blank" rel="noopener">
        <span class="sr-only">{title}</span>
        <Sprite aria-hidden="true" name={icon} />
      </a>
    ))
  }
</footer>
<div id="social-tooltip" class="tooltip" role="tooltip" hidden data-themable>
  <span class="tooltip-content"></span>
  <span class="tooltip-arrow"></span>
</div>

<style>
  footer {
    --start: 32px;
    --end: 40px;

    display: flex;
    justify-content: flex-end;
    gap: 12px;
    margin-block: var(--start) var(--end);

    @media (width >= 720px) {
      --start: 40px;
      --end: 56px;
    }
  }

  a {
    --size: 40px;

    display: flex;
    justify-content: center;
    align-items: center;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-social);
    transition:
      bordercolor 0.25s var(--ease-in-out),
      color 0.25s var(--ease-in-out),
      background-color 0.25s var(--ease-in-out);
    width: var(--size);
    height: var(--size);

    @media (width >= 1100px) {
      --size: 44px;
    }

    &:hover {
      background-color: var(--bg);
    }
  }

  :global([data-theme='dark']) a {
    --bg: rgba(255 255 255 / 6%);
  }

  :global([data-theme='light']) a {
    --bg: rgba(92 73 61 / 6%);
  }

  [astro-icon] {
    --size: 24px;

    width: var(--size);
    aspect-ratio: 1;

    @media (width >= 1100px) {
      --size: 28px;
    }
  }

  [astro-icon='ri:linkedin-line'] {
    margin-top: -2px;
  }

  [astro-icon='ri:twitter-x-line'] {
    --size: 22px;

    @media (width >= 1100px) {
      --size: 24px;
    }
  }
</style>
