---
import { Image } from 'astro:assets';

import pictureSrc from '@/images/jmlweb.jpg';

import Container from '../Container.astro';
import Strong from '../Strong.astro';
import SocialLinks from './SocialLinks.astro';
---

<div
  class:list={[
    'transition-colors',
    'bg-gradient-to-rb from-15% to-55% from-indigo-200/13 to-indigo-200/7 d:from-orange-200/4 d:to-indigo-900/7',
    'border-y border-cinder-400/10 d:border-cinder-200/10',
  ]}
>
  <Container as="section">
    <div class="flex flex-col lg:flex-row lg:items-center lg:gap-12">
      <div class="flex-1 lg:mt-12">
        <h1
          class:list={[
            'text-3xl md:text-4xl font-bold',
            'text-cinder-800/90 d:text-cinder-100/90',
            'tracking-tight',
            'transition-colors',
          ]}
        >
          ¡Hola! Soy <br class="sm:hidden" aria-hidden="true" />José Manuel
          Lucas
        </h1>
        <p
          class:list={[
            'text-xl lg:text-2xl font-medium',
            'mt-2',
            'text-cinder-500/80 d:text-cinder-300/80',
            'transition-colors',
          ]}
        >
          Construyo sitios web escalables y eficientes basados en buenas
          prácticas y estándares
        </p>
        <p class="mt-3 lg:text-lg transition-colors">
          Aunque estoy especializado en desarrollo Frontend con
          <Strong>TypeScript</Strong>, también maqueto con <Strong>HTML</Strong>
          y <Strong>CSS</Strong>, me siento cómodo en el lado servidor y hasta
          hago mis pinitos preparando los pipelines de <Strong>CI/CD</Strong>.
        </p>
      </div>
      <Image
        src={pictureSrc}
        width={pictureSrc.width / 2}
        alt="Fotografía de José Manuel Lucas"
        densities={[1.5, 2]}
        loading="eager"
        class:list={[
          'block',
          'w-20 md:w-24 lg:w-32',
          'mt-6 lg:mt-8 mb-3 md:mb-4',
          'aspect-square',
          'rounded-full overflow-hidden',
          'order-first',
        ]}
      />
    </div>
    <SocialLinks />
  </Container>
</div>
