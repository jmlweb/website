---
import type { HTMLTag, Polymorphic } from 'astro/types';

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }>;

const { as: Tag = 'div', class: className, ...rest } = Astro.props;
---

<Tag
  class:list={[
    'max-w-full w-6xl',
    'mx-auto',
    'px-5 md:px-8 lg:px-12',
    className,
  ]}
  {...rest}
>
  <slot />
</Tag>
