---
import type { HTMLTag, Polymorphic } from 'astro/types';

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }>;

const { as: Tag = 'div', class: className, ...rest } = Astro.props;
---

<Tag data-container class:list={['container', className]} {...rest}>
  <slot />
</Tag>

<style>
  .container {
    --x-space: 20px;

    width: 100%;
    max-width: 1196px;
    margin-inline: auto;
    padding-inline: var(--x-space);

    @media (width >= 720px) {
      --x-space: 32px;
    }

    @media (width >= 1100px) {
      --x-space: 48px;
    }
  }
</style>
