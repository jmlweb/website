---
import { Image } from 'astro:assets';
import { twMerge } from 'tailwind-merge';

import pictureSrc from '@/images/jmlweb.jpg';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<Image
  src={pictureSrc}
  widths={[180, 240, 320]}
  sizes="(max-width: 520px) 180px, (max-width: 980px) 240px, 320px"
  alt=""
  loading="eager"
  class={twMerge(
    'inline-block max-w-xs object-cover object-center max-w-[180px] sm:max-w-[240px] lg:max-w-[320px] transition-all',
    className,
  )}
/>
