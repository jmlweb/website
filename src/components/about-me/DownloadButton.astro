---
interface Props {
  href: string;
  title: string;
  subtitle: string;
  lang?: 'en';
}

const { href, title, subtitle, lang } = Astro.props;
---

<a
  class:list={[
    'relative flex flex-col justify-between items-center flex-1 lg:flex-none',
    'py-2 sm:py-3 px-8 rounded-1.25',
    'text-base font-bold whitespace-nowrap',
    'transition-colors shadow-md shadow-cinder-950/30 d:shadow-black/80 text-shadow-sm',
    'bg-indigo-600  text-indigo-100 d:text-indigo-100 @hover:bg-indigo-700 d:@hover:bg-indigo-500 @hover:text-indigo-50 d:@hover:text-indigo-50',
    'border border-indigo-700 d:border-indigo-500 @hover:border-indigo-800 d:@hover:border-indigo-400',
    'after:content-empty after:absolute after:inset-0 after:-z-1 after:rotate-5 after:pointer-events-none after:translate-z-0',
    'after:rounded-lg after:blur-xl after:transition-opacity after:opacity-0 after:@hover:opacity-100',
    'after:bg-indigo-200/50 after:d:bg-indigo-500/40',
  ]}
  href={href}
  lang={lang}
  hreflang={lang}
>
  <span>{title}</span>
  <span class="text-sm font-medium text-indigo-200 -mt-0.7 md:-mt-0.5"
    >{subtitle}</span
  >
</a>
