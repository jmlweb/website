---
import type { HTMLTag, Polymorphic } from 'astro/types';
import { twMerge } from 'tailwind-merge';

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }>;

const { as: Tag = 'h2', class: className, ...rest } = Astro.props;
---

<Tag
  class={twMerge(
    'text-2xl lg:text-3xl font-medium leading-tight tracking-tight',
    'text-cinder-500/80 d:text-cinder-300/80 ',
    className,
  )}
  {...rest}
>
  <slot />
</Tag>
