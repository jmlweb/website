---
import Container from '@/components/Container.astro';
import { SOCIAL_NETWORKS } from '@/config/socialNetworks';
---

<Container
  as="footer"
  class:list={[
    'flex flex-col',
    'lg:flex-row lg:justify-between',
    'gap-4',
    'mt-auto',
    'pt-24 pb-8 lg:pt-40',
    'text-[15px] md:text-base lg:text-[17px]',
  ]}
>
  <ul class="flex flex-wrap justify-center font-medium lg:-ml-3">
    {
      SOCIAL_NETWORKS.map(({ href, title }) => (
        <li>
          <a
            class="block py-2 px-3 text-orange-700 d:text-orange-200 @hover:underline"
            href={href}
            target="_blank"
            rel="noopener noreferrer"
          >
            {title}
          </a>
        </li>
      ))
    }
  </ul>
  <ul class="flex flex-wrap justify-center items-center gap-y-2 gap-x-5">
    <li class="font-semibold w-full text-center md:w-auto md:text-left">
      José Manuel Lucas
    </li>
    <li>
      <a
        class="block py-2 mt-1 md:text-[15px] lg:text-base md:mt-0 text-cinder-500 d:text-cinder-300 @hover:underline"
        href="/condiciones-legales">Términos de uso</a
      >
    </li>
    <li>
      <a
        class="block py-2 mt-1 md:text-[15px] lg:text-base md:mt-0 text-cinder-500 d:text-cinder-300 @hover:underline"
        href="/politica-privacidad">Política de privacidad</a
      >
    </li>
  </ul>
</Container>
